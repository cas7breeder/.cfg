{
    "vscode-neovim.enableNeovimOnly": true,
    "workbench.editor.useModal": "off",
    "zenMode.hideLineNumbers": false,
    "window.menuBarVisibility": "hidden",
    "editor.wordWrap": "off",
    "editor.scrollbar.verticalScrollbarSize": 5,
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "editor.renderWhitespace": "trailing",
    "editor.lineNumbers": "relative",
    "editor.formatOnSave": true,
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "workbench.view.showQuietly": {
        "workbench.panel.output": true
    },
    // Caps-lock remap fix on gnome+wayland
    "keyboard.dispatch": "keyCode",
    "editor.minimap.enabled": false,
    "workbench.colorTheme": "One Dark Pro Darker",
    "editor.cursorBlinking": "solid",
    "editor.cursorSmoothCaretAnimation": "off",
    "workbench.colorCustomizations": {
        "focusBorder": "#00ff88BB",
        // Cursor
        "editorCursor.foreground": "#FFD700",
        "editorCursor.background": "#000000",
        // Visual selection background
        "editor.selectionBackground": "#2a4f86aa",
        // When finding and has matching text objects - this is their color
        "editor.selectionHighlightBackground": "#00000000",
        "editor.selectionHighlightBorder": "#00000000",
        // Word occurence highlight
        "editor.wordHighlightBackground": "#00000000",
        "editor.wordHighlightBorder": "#a6a6a6dd",
        // Find coloring
        "editor.findMatchBackground": "#00000000",
        "editor.findMatchHighlightBackground": "#00000000",
        "editor.findMatchBorder": "#FFD700",
        "editor.findMatchHighlightBorder": "#FFFFFFCC",
        // Other
        "editorWhitespace.foreground": "#6dcc6d",
        "editorLineNumber.foreground": "#3b7f68",
        "list.activeSelectionBackground": "#2a4f86aa",
        "list.inactiveSelectionBackground": "#2a4f86aa"
    },
    // Auto-completion, intellisense, quickSuggestions
    "editor.inlineSuggest.enabled": true,
    "editor.tabCompletion": "onlySnippets",
    //"workbench.iconTheme": "quill-icons-minimal",
    // Controls whether opened editors show as preview. Preview editors are reused until they are kept (e.g. via double click or editing) and show up with an italic font style.
    //"workbench.editor.enablePreview": false
}
