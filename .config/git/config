[user]
    name = cas7breeder
    email = castbreeder@posteo.net

[core]
    editor = /usr/bin/nvim
    autocrlf = input

[alias]
    st = status
    df = diff
    dfi = diff --cached
    co = checkout
    cm = commit -m
    cma = commit --amend
    br = branch -vv
    cb = checkout -b
    lga = log --graph --oneline --all --decorate
    lo = log --oneline
    stu = stash --include-untracked
    stl = stash list
    stp = stash pop
    po = push origin HEAD
    pof = push -f origin HEAD
    sw = switch

# Disabled for now as it tends to delete the email record between checkouts
[filter "demail_git_config"]
    clean = "sed '/^\\s*email\\s*=/'d"

[pull]
    ff = only

[color "status"]
    added = 76
    changed = 167
    untracked = 167
    branch = 227 bold
    localBranch = 76
    remoteBranch = 167
    nobranch = 167 bold
    unmerged = 167 bold

[color "branch"]
    current = yellow bold
    local = 76 bold
    remote = 167
    upstream = 167 bold

[color "diff"]
    old = "#d80000"
    new = "#00d000"
    whitespace = "#d80000" "#eeeeee" bold

[color "decorate"]
    branch = 76 bold
    remoteBranch = 167 bold
    tag = 99 bold
    HEAD = yellow bold

[init]
    defaultBranch = master
