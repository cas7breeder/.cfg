// Place your key bindings in this file to override the defaults
[
    // ---------- UNMAP SECTION ----------
    {
        "key": "ctrl+w",
        "command": "-workbench.action.closeActiveEditor",
    },
    {
        "command": "-workbench.action.closeWindow",
        "key": "ctrl+shift+w"
    },
    {
        "command": "-workbench.action.quit",
        "key": "ctrl+q"
    },
    {
        "command": "-workbench.action.zoomIn",
        "key": "ctrl+="
    },
    {
        "command": "-workbench.action.zoomOut",
        "key": "ctrl+-"
    },
    {
        "command": "-workbench.action.moveEditorToNextGroup",
        "key": "ctrl+alt+right"
    },
    {
        "command": "-workbench.action.moveEditorToPreviousGroup",
        "key": "ctrl+alt+left"
    },
    {
        "command": "-workbench.action.moveEditorToRightGroup",
        "key": "alt+right"
    },
    {
        "command": "-workbench.action.moveEditorToLeftGroup",
        "key": "alt+left"
    },
    {
        "key": "ctrl+,",
        "command": "-workbench.action.openSettings",
    },
    {
        "key": "ctrl+s",
        "command": "-workbench.action.files.save",
    },
    {
        "key": "ctrl+f",
        "command": "-actions.find",
    },
    {
        "key": "ctrl+h",
        "command": "-editor.action.startFindReplaceAction",
    },
    {
        "key": "ctrl+shift+s",
        "command": "-workbench.action.files.saveLocalFile"
    },
    // -----------------------------------
    // Open workspace
    {
        "command": "workbench.action.openWorkspace",
        "key": "ctrl+k ctrl+l"
    },
    // Resize panels
    {
        "command": "workbench.action.evenEditorWidths",
        "key": "ctrl+shift+q",
        "when": "editorFocus"
    },
    {
        "command": "workbench.action.toggleMaximizedPanel",
        "key": "ctrl+q",
        "when": "terminalFocus"
    },
    {
        "command": "workbench.action.minimizeOtherEditors",
        "key": "ctrl+q",
        "when": "editorFocus"
    },
    // Manual editor resize
    {
        "command": "workbench.action.increaseViewSize",
        "key": "alt+="
    },
    {
        "command": "workbench.action.decreaseViewSize",
        "key": "alt+-"
    },
    // Split terminal
    {
        "command": "workbench.action.terminal.split",
        "key": "ctrl+\\",
        "when": "terminalFocus"
    },
    // ------ Navigation
    {
        "command": "list.focusDown",
        "key": "j",
        "when": "listFocus && !inputFocus"
    },
    {
        "command": "list.focusUp",
        "key": "k",
        "when": "listFocus && !inputFocus"
    },
    // Quick suggestions' dropdown navigation
    {
        "key": "ctrl+j",
        "command": "selectNextSuggestion",
        "when": "neovim.mode != 'visual' && editorTextFocus  && suggestWidgetVisible && suggestWidgetHasFocusedSuggestion"
    },
    {
        "key": "ctrl+k",
        "command": "selectPrevSuggestion",
        "when": "neovim.mode != 'visual' && editorTextFocus  && suggestWidgetVisible && suggestWidgetHasFocusedSuggestion"
    },
    {
        "key": "ctrl+d",
        "command": "selectNextPageSuggestion",
        "when": "neovim.mode != 'visual' && editorTextFocus  && suggestWidgetVisible && suggestWidgetHasFocusedSuggestion"
    },
    {
        "key": "ctrl+u",
        "command": "selectPrevPageSuggestion",
        "when": "neovim.mode != 'visual' && editorTextFocus  && suggestWidgetVisible && suggestWidgetHasFocusedSuggestion"
    },
    // Quick open dropdown navigation
    {
        "key": "ctrl+j",
        "command": "workbench.action.quickOpenSelectNext",
        "when": "inQuickOpen"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.quickOpenSelectPrevious",
        "when": "inQuickOpen"
    },
    // Navigate between open editors
    {
        "command": "workbench.action.nextEditorInGroup",
        "key": "ctrl+alt+l",
        "when": "!activeEditorIsLastInGroup"
    },
    {
        "command": "workbench.action.focusRightGroup",
        "key": "ctrl+alt+l",
        "when": "activeEditorIsLastInGroup"
    },
    {
        "command": "workbench.action.previousEditorInGroup",
        "key": "ctrl+alt+h",
        "when": "!activeEditorIsFirstInGroup"
    },
    {
        "command": "workbench.action.focusLeftGroup",
        "key": "ctrl+alt+h",
        "when": "activeEditorIsFirstInGroup"
    },
    // Move focus
    {
        "command": "workbench.action.navigateLeft",
        "key": "alt+h"
    },
    {
        "command": "workbench.action.navigateRight",
        "key": "alt+l",
        "when": "!replaceActive"
    },
    {
        "command": "workbench.action.navigateUp",
        "key": "alt+k"
    },
    {
        "command": "workbench.action.navigateDown",
        "key": "alt+j"
    },
    // Navigate between terminal panes
    {
        "command": "workbench.action.terminal.focusPreviousPane",
        "key": "alt+h",
        "when": "terminalFocus"
    },
    {
        "command": "workbench.action.terminal.focusNextPane",
        "key": "alt+l",
        "when": "terminalFocus"
    },
    // Show all opened editors
    {
        "command": "workbench.action.showAllEditors",
        "key": "space ,",
        "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus) && !filesExplorerFocus"
    },
    // Go to file/ quick open
    {
        "key": "space space",
        "command": "workbench.action.quickOpen",
        "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus) && !filesExplorerFocus"
    },
    // Open/focus files explorer
    {
        "command": "workbench.files.action.focusFilesExplorer",
        "key": "space e",
        "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus) && !filesExplorerFocus && !sideBarFocus"
    },
    {
        "key": "escape",
        "command": "workbench.action.closeSidebar",
        "when": "filesExplorerFocus && !inputFocus"
    },
    // Move tab to the opposite group
    {
        "command": "workbench.action.moveEditorToLeftGroup",
        "key": "alt+shift+h",
        "when": "(editorTextFocus || inSettingsEditor || inKeybindings || inWelcome"
    },
    {
        "command": "workbench.action.moveEditorToRightGroup",
        "key": "alt+shift+l",
        "when": "editorTextFocus || inSettingsEditor || inKeybindings || inWelcome"
    },
    // Toggle Zen mode
    {
        "key": "space z",
        "command": "workbench.action.toggleZenMode",
        "when": "neovim.mode != 'insert' && editorTextFocus && !filesExplorerFocus"
    },
    // ------ File/editor actions
    // Open new blank file
    {
        "command": "workbench.action.files.newUntitledFile",
        "key": "alt+n",
        "when": "neovim.mode != 'insert'"
    },
    // Close file
    {
        "command": "workbench.action.closeActiveEditor",
        "key": "alt+q",
        "when": "neovim.mode != 'insert' && (editorTextFocus || inSettingsEditor || inKeybindings || inWelcome)"
    },
    {
        "command": "workbench.action.closeFolder",
        "key": "alt+shift+q",
        "when": "neovim.mode != 'insert' && (editorTextFocus || inSettingsEditor || inKeybindings || inWelcome)"
    },
    // Save file
    {
        "command": "workbench.action.files.save",
        "key": "space s",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    {
        "key": "ctrl+shift+s",
        "command": "workbench.action.saveWorkspaceAs",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    // Split editor vertically
    {
        "command": "workbench.action.splitEditorToRightGroup",
        "key": "space v",
        "when": "neovim.mode == 'normal' && editorTextFocus && !activeEditorGroupLast && !filesExplorerFocus"
    },
    {
        "command": "workbench.action.splitEditorToLeftGroup",
        "key": "space v",
        "when": "neovim.mode == 'normal' && editorTextFocus && activeEditorGroupLast && !filesExplorerFocus"
    },
    // Split editor horizontally
    {
        "command": "workbench.action.splitEditorDown",
        "key": "space h",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    {
        "command": "workbench.action.closeOtherEditors",
        "key": "space t",
        "when": "neovim.mode != 'insert' && editorTextFocus && !filesExplorerFocus"
    },
    {
        "key": "shift+h",
        "command": "list.focusFirst",
        "when": "filesExplorerFocus"
    },
    {
        "key": "shift+l",
        "command": "list.focusLast",
        "when": "filesExplorerFocus"
    },
    {
        "key": "space",
        "command": "list.toggleSelection",
        "when": "filesExplorerFocus"
    },
    {
        "key": "escape",
        "command": "list.closeFindWidget",
        "when": "filesExplorerFocus && listFindWidgetVisible"
    },
    // ------ Coding shortcuts
    // Show hover tooltip - object info
    {
        "command": "editor.action.showHover",
        "key": "shift-k",
        "when": "neovim.mode == 'normal' && editorTextFocus"
    },
    // Open quick fix dialogue - same as ctrl+.
    {
        "command": "editor.action.quickFix",
        "key": "space a",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    // Go to symbol
    {
        "command": "workbench.action.gotoSymbol",
        "key": "space k",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    // Reveal definition similar to 'g d' - but uses LSP
    {
        "command": "editor.action.revealDefinition",
        "key": "space g d",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    // Go to implementation
    {
        "command": "editor.action.goToImplementation",
        "key": "space g i",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    // Open references
    {
        "command": "editor.action.goToReferences",
        "key": "space g r",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    // Rename variable
    {
        "command": "editor.action.rename",
        "key": "space r",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus && editorHasRenameProvider"
    },
    // Replace word under cursor
    {
        "command": "runCommands",
        "args": {
            "commands": [
                "actions.findWithSelection",
                {
                    "command": "editor.actions.findWithArgs",
                    "args": {
                        "isRegex": false,
                        "matchWholeWord": true,
                        "isCaseSensitive": true,
                    }
                },
                {
                    "command": "toggleFindInSelection",
                    "when": "editorHasSelection"
                },
                "editor.action.startFindReplaceAction"
            ]
        },
        "key": "space r",
        "when": "neovim.mode != 'insert' && editorTextFocus && !editorHasRenameProvider && !filesExplorerFocus"
    },
    // Find remap
    {
        "command": "editor.actions.findWithArgs",
        "args": {
            "findInSelection": false,
            "isCaseSensitive": false,
            "isRegex": true,
            "matchWholeWord": false
        },
        "key": "space f",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    {
        "command": "runCommands",
        "args": {
            "commands": [
                "actions.findWithSelection",
                {
                    "command": "editor.actions.findWithArgs",
                    "args": {
                        "findInSelection": false,
                        "isCaseSensitive": false,
                        "isRegex": true,
                        "matchWholeWord": false
                    },
                }
            ]
        },
        "key": "space n",
        "when": "neovim.mode == 'normal' && editorTextFocus && !filesExplorerFocus"
    },
    // Join lines in visual mode
    {
        "command": "editor.action.joinLines",
        "key": "space j",
        "when": "neovim.mode == 'visual' && editorTextFocus && !filesExplorerFocus"
    },
    // Find word under cursor and add to selection
    {
        "key": "ctrl-n",
        "command": "editor.action.addSelectionToNextFindMatch",
        "when": "neovim.mode != 'insert' && (editorTextFocus || !inputFocus)"
    },
    {
        "key": "space `",
        "command": "copyRelativeFilePath",
        "when": "neovim.mode != 'insert' && editorTextFocus && !filesExplorerFocus"
    },
    {
        "key": "`",
        "command": "copyRelativeFilePath",
        "when": "filesExplorerFocus"
    },
    // Passthrough to nvim
    {
        // Send this input to Neovim.
        "command": "vscode-neovim.send",
        "args": "<Space>p",
        // Invoke the binding with this key sequence.
        "key": "space p",
        "when": "neovim.mode != 'insert' && editorTextFocus && !filesExplorerFocus"
    },
    // Zoomiz extension
    {
        "key": "space l",
        "command": "zoomiz.jump",
        "when": "neovim.mode != 'insert' && editorTextFocus && !filesExplorerFocus"
    }
]
